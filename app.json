{
  "expo": {
    "name": "PawShop",
    "slug": "pawshop",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pawshop",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF8F2"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.pawshop",
      "infoPlist": {
        "NSCameraUsageDescription": "PawShop needs camera access to take pet photos.",
        "NSPhotoLibraryUsageDescription": "PawShop needs photo library access to select pet images."
      }
    },
    "android": {
      "package": "com.pawshop",
      "adaptiveIcon": {
        "backgroundColor": "#FFF8F2",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": ["android.permission.CAMERA", "android.permission.READ_MEDIA_IMAGES"]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-image-picker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
